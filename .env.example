# ========================================
# SVS Agent - Arquivo de Exemplo de Variáveis de Ambiente
# ========================================
# Copie este arquivo para .env e preencha com seus valores

# ========================================
# CONFIGURAÇÃO DO SITE ALVO
# ========================================
# URL do site que será monitorado
TARGET_SITE_URL=https://svs-solucoes.surge.sh

# ========================================
# CONFIGURAÇÃO DO GITHUB
# ========================================
# Owner do repositório GitHub
GITHUB_REPO_OWNER=SidneyJuniorxz

# Nome do repositório GitHub
GITHUB_REPO_NAME=SITE-SVS

# Token de acesso pessoal do GitHub (com permissões: repo, read:user)
# Gere em: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ========================================
# BANCO DE DADOS
# ========================================
# URL de conexão com o banco de dados MySQL/TiDB
# Formato: mysql://username:password@host:port/database
DATABASE_URL=mysql://user:password@localhost:3306/svs_agent

# ========================================
# AUTENTICAÇÃO
# ========================================
# Secret para assinar JWT tokens
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ========================================
# MANUS OAUTH
# ========================================
# ID da aplicação Manus OAuth
VITE_APP_ID=your-manus-app-id

# URL do servidor OAuth Manus
OAUTH_SERVER_URL=https://api.manus.im

# URL do portal de login Manus
VITE_OAUTH_PORTAL_URL=https://manus.im/login

# ========================================
# MANUS BUILT-IN APIs
# ========================================
# Chave de API para usar as APIs Manus (server-side)
BUILT_IN_FORGE_API_KEY=your-forge-api-key

# URL base das APIs Manus
BUILT_IN_FORGE_API_URL=https://api.manus.im

# Chave de API para o frontend acessar as APIs Manus
VITE_FRONTEND_FORGE_API_KEY=your-frontend-forge-api-key

# URL base das APIs Manus (para o frontend)
VITE_FRONTEND_FORGE_API_URL=https://api.manus.im

# ========================================
# INFORMAÇÕES DO PROPRIETÁRIO
# ========================================
# Open ID do proprietário da aplicação (obtido do OAuth)
OWNER_OPEN_ID=your-owner-open-id

# Nome do proprietário
OWNER_NAME=Admin

# ========================================
# ANALYTICS (OPCIONAL)
# ========================================
# Endpoint de analytics (se usar)
VITE_ANALYTICS_ENDPOINT=

# ID do website para analytics
VITE_ANALYTICS_WEBSITE_ID=

# ========================================
# CONFIGURAÇÃO DE MONITORAMENTO
# ========================================
# Intervalo de verificação de uptime (em milissegundos)
# Padrão: 300000 (5 minutos)
UPTIME_CHECK_INTERVAL=300000

# Intervalo de análise de SEO (em milissegundos)
# Padrão: 86400000 (24 horas)
SEO_ANALYSIS_INTERVAL=86400000

# Intervalo de verificação de performance (em milissegundos)
# Padrão: 3600000 (1 hora)
PERFORMANCE_CHECK_INTERVAL=3600000

# ========================================
# AMBIENTE
# ========================================
# Ambiente de execução: development ou production
NODE_ENV=development

# Porta na qual o servidor será executado
PORT=3000
